{
  "expo": {
    "name": "stead",
    "slug": "stead",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patelarya.stead"
    },
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "stead reads your steps to make timely nudges.",
          "NSHealthUpdateUsageDescription": "stead may write workout activity you choose to track."
        }
      ],
      "expo-notifications"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.patelarya.stead"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
